# KIE API key (required)
KIE_API_KEY=your_kie_api_key_here

# Server port (default: 8420)
# KIE_PORT=8420

# Frontend authentication key
# API_KEY=brick-squad-2026

# Webhook callback URL (set in production)
# KIE_CALLBACK_URL=https://your-domain.com/api/kie-callback

# HMAC key for webhook verification (set in production)
# KIE_WEBHOOK_KEY=your_webhook_hmac_key

# JWT secret for authentication (must be at least 32 bytes for SHA256)
# JWT_SECRET=your-secret-key-min-32-chars-long
